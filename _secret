#compdef secret
# Tab completion for the `secret` CLI (~/.local/bin/secret).
# Subcommands; for get/update/rm it completes key names from `secret list`.

local curcontext="$curcontext" state line
local -a subcmds

subcmds=(
  'list:List all managed secret names'
  'get:Print a secret value to stdout'
  'add:Add a new secret'
  'update:Update an existing secret'
  'rm:Delete a secret'
)

_arguments -C \
  '1: :->cmd' \
  '*:: :->args'

case $state in
  cmd)
    _describe -t commands 'secret command' subcmds
    ;;
  args)
    case $line[1] in
      get|update|rm|delete)
        local -a names
        names=(${(f)"$(secret list 2>/dev/null)"})
        _describe -t secrets 'secret name' names
        ;;
    esac
    ;;
esac
