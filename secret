#!/usr/bin/env bash
# secret — macOS Keychain wrapper for agent-managed secrets
#
# All entries managed by this tool share a fixed account field ("agent-secrets")
# so `list` can filter them out of the general keychain.
#
# Usage:
#   secret list              List all managed secret names
#   secret list -l           List names + descriptions (long format)
#   secret get <name>        Print password to stdout (exits 1 on missing/empty/locked)
#   secret add <name> [desc] Add a new secret (hidden prompt for value, or stdin)
#   secret update <name> [desc]
#                            Update existing secret. Desc optional; omitted => keep current.
#   secret rm <name>         Delete a secret

set -euo pipefail

VERSION="0.1.0"
ACCOUNT="agent-secrets"

usage() {
  local dest="${1:-stderr}"
  local body
  body=$(cat <<'EOF'
secret — macOS Keychain wrapper for agent-managed secrets

All entries share account field "agent-secrets" so `list` filters out the
general keychain. Designed for scripted/agent use: `get` fails loudly
instead of returning empty on missing/locked entries.

Usage:
  secret list                   List all managed secret names
  secret list -l | --long       List names + descriptions (table)
  secret get <name>             Print password to stdout
                                (exits 1 on missing/empty/locked, errors to stderr)
  secret add <name> [desc]      Add new secret
                                Value: hidden prompt if tty, else reads stdin
                                Desc:  optional, stored as keychain comment
  secret update <name> [desc]   Update existing secret
                                Desc omitted => existing description kept
  secret rm <name>              Delete a secret
  secret -V | --version         Print version
  secret -h | --help            Show this help

Examples:
  # Add with description
  secret add aliyun-main-access-key-id "阿里云主账号 access key id"

  # Add from pipe (value not stored in shell history as literal)
  pbpaste | secret add databricks-dev-token "Databricks dev workspace PAT"

  # Use in a command without exporting to shell
  ALIBABA_CLOUD_ACCESS_KEY_ID=$(secret get aliyun-main-access-key-id) \
    aliyun ecs DescribeInstances

  # Browse what exists
  secret list -l

Storage: macOS Keychain (~/Library/Keychains/login.keychain-db)
         Unlocked automatically when you log in to macOS.
EOF
)
  if [[ "$dest" == "stdout" ]]; then
    printf '%s\n' "$body"
  else
    printf '%s\n' "$body" >&2
  fi
}

read_value() {
  local name="$1" val
  if [[ -t 0 ]]; then
    read -rs -p "Enter value for '$name': " val
    echo >&2
  else
    IFS= read -r val
  fi
  [[ -n "$val" ]] || { echo "ERROR: empty value not allowed" >&2; return 1; }
  printf '%s' "$val"
}

cmd_list() {
  local long=0
  case "${1:-}" in
    -h|--help)
      cat <<'EOF'
secret list [-l|--long]
  List managed secret names.
  -l, --long    Show names with descriptions (tab-aligned table)
EOF
      return 0 ;;
    -l|--long) long=1 ;;
    "") ;;
    *) echo "Unknown flag for list: $1" >&2; return 1 ;;
  esac

  local rows
  rows=$(security dump-keychain 2>/dev/null | awk -v acct="$ACCOUNT" -v long="$long" '
    function hex2str(h,   s, i, n, c, hi, lo, HEX) {
      HEX = "0123456789ABCDEF"
      sub(/^0x/, "", h); sub(/[ \t]+$/, "", h)
      s = ""; n = length(h)
      for (i = 1; i <= n; i += 2) {
        hi = index(HEX, toupper(substr(h, i, 1))) - 1
        lo = index(HEX, toupper(substr(h, i+1, 1))) - 1
        s = s sprintf("%c", hi * 16 + lo)
      }
      return s
    }
    function parse_blob(line,   v) {
      v = line
      sub(/.*<blob>=/, "", v)
      sub(/[ \t]+$/, "", v)
      if (v ~ /^"/) {
        sub(/^"/, "", v); sub(/"$/, "", v)
        return v
      } else if (v ~ /^0x/) {
        # hex form may be followed by whitespace + quoted repr; keep only hex
        sub(/[ \t].*$/, "", v)
        return hex2str(v)
      }
      return ""
    }
    BEGIN { RS="keychain: "; FS="\n" }
    {
      has_acct=0; svc=""; desc=""
      for (i=1; i<=NF; i++) {
        if ($i ~ "\"acct\"<blob>=\"" acct "\"") has_acct=1
        if ($i ~ /"svce"<blob>=/) svc = parse_blob($i)
        if ($i ~ /"icmt"<blob>=/) desc = parse_blob($i)
      }
      if (has_acct && svc != "") {
        if (long) printf "%s\t%s\n", svc, desc
        else print svc
      }
    }
  ' | LC_ALL=C sort -u)

  if [[ "$long" -eq 1 ]]; then
    { printf "NAME\tDESCRIPTION\n"; echo "$rows"; } | column -t -s $'\t'
  else
    echo "$rows"
  fi
}

cmd_get() {
  case "${1:-}" in
    -h|--help)
      cat <<'EOF'
secret get <name>
  Print password to stdout. Does NOT append a newline, so $(secret get X) is clean.
  Exits 1 with stderr message if the entry is missing, empty, or the keychain is locked.
EOF
      return 0 ;;
  esac
  local name="${1:?secret name required}" val
  if ! val=$(security find-generic-password -a "$ACCOUNT" -s "$name" -w 2>/dev/null); then
    echo "ERROR: secret '$name' not found or keychain locked" >&2
    return 1
  fi
  [[ -n "$val" ]] || { echo "ERROR: secret '$name' is empty" >&2; return 1; }
  printf '%s' "$val"
}

cmd_add() {
  case "${1:-}" in
    -h|--help)
      cat <<'EOF'
secret add <name> [description]
  Add a new secret. Rejects if <name> already exists (use `secret update`).
  Value: hidden tty prompt, or read from stdin if piped.
  Description: optional, free-form text stored as keychain comment (icmt).
EOF
      return 0 ;;
  esac
  local name="${1:?secret name required}"
  local desc="${2:-}"
  if security find-generic-password -a "$ACCOUNT" -s "$name" >/dev/null 2>&1; then
    echo "ERROR: secret '$name' already exists. Use 'secret update $name'." >&2
    return 1
  fi
  local val; val=$(read_value "$name")
  local args=(-a "$ACCOUNT" -s "$name" -w "$val")
  [[ -n "$desc" ]] && args+=(-j "$desc")
  security add-generic-password "${args[@]}"
  echo "Added: $name" >&2
}

cmd_update() {
  case "${1:-}" in
    -h|--help)
      cat <<'EOF'
secret update <name> [description]
  Replace password for an existing secret. Rejects if <name> doesn't exist.
  Value: hidden tty prompt, or read from stdin if piped.
  Description: optional. If omitted, the existing description is kept unchanged.
EOF
      return 0 ;;
  esac
  local name="${1:?secret name required}"
  local desc="${2:-}"
  if ! security find-generic-password -a "$ACCOUNT" -s "$name" >/dev/null 2>&1; then
    echo "ERROR: secret '$name' does not exist. Use 'secret add $name'." >&2
    return 1
  fi
  local val; val=$(read_value "$name")
  local args=(-a "$ACCOUNT" -s "$name" -w "$val" -U)
  [[ -n "$desc" ]] && args+=(-j "$desc")
  security add-generic-password "${args[@]}"
  echo "Updated: $name" >&2
}

cmd_rm() {
  case "${1:-}" in
    -h|--help)
      cat <<'EOF'
secret rm <name>
  Delete a secret. No confirmation prompt.
EOF
      return 0 ;;
  esac
  local name="${1:?secret name required}"
  security delete-generic-password -a "$ACCOUNT" -s "$name" >/dev/null
  echo "Deleted: $name" >&2
}

case "${1:-}" in
  list)       shift; cmd_list "$@" ;;
  get)        shift; cmd_get "$@" ;;
  add)        shift; cmd_add "$@" ;;
  update)     shift; cmd_update "$@" ;;
  rm|delete)  shift; cmd_rm "$@" ;;
  -V|--version|version) echo "secret $VERSION" ;;
  -h|--help)  usage stdout ;;
  "")         usage stderr; exit 1 ;;
  *)          echo "Unknown command: $1" >&2; usage stderr; exit 1 ;;
esac
